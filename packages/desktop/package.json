{
  "name": "@ai-companion/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsup --config tsup.config.ts",
    "build:preload": "echo preload built by tsup.config.ts",
    "build:renderer": "tsup src/renderer/index.tsx --format iife --outDir dist/renderer --global-name=App --no-config && node -e \"require('fs').cpSync('src/renderer/index.html','dist/renderer/index.html')\"",
    "dev": "npm run build && electron .",
    "start": "electron ."
  },
  "dependencies": {
    "@ai-companion/core": "*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "electron": "^33.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
